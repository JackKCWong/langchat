# langchat auto-loads this file from the current working directory at startup.
# Existing environment variables take precedence over values defined here.

# OpenAI-compatible endpoint. Leave unset to use OpenAI's default.
# For DeepSeek:  https://api.deepseek.com/v1
# For Ollama:    http://localhost:11434/v1
# For LM Studio: http://localhost:1234/v1
# LANGCHAT_BASE_URL=

# Required: the model name to send to /chat/completions.
LANGCHAT_MODEL=gpt-4o-mini

# Optional. Falls back to OPENAI_API_KEY when unset.
# If still unset, langchat warns and uses a placeholder so local servers
# (Ollama, LM Studio, vLLM) work without authentication.
# LANGCHAT_API_KEY=sk-...

# Optional sampling / runtime defaults. Any of these can also be set per
# chat file via a "---" frontmatter header (CLI flag > header > env).
# LANGCHAT_TEMPERATURE=0.7
# LANGCHAT_TOP_P=1
# LANGCHAT_MAX_TOKENS=1024
# LANGCHAT_TIMEOUT=60000
# LANGCHAT_MAX_RETRIES=2